/* pages/chat/chat.wxss */
page {
  height: 100%;
  background: #f5f5f7;
}

.chat-container {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.messages {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.message {
  display: flex;
  margin-bottom: 30rpx;
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #34C759;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.message.assistant .avatar {
  background: #007AFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.content {
  max-width: 480rpx;
  margin: 0 20rpx;
}

.Bubble {
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
  background: white;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.message.user .Bubble {
  background: #007AFF;
  color: white;
}

.time {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.message.user .time {
  text-align: right;
}

.typing {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background: white;
  border-radius: 24rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: #999;
  border-radius: 50%;
  margin: 0 4rpx;
  animation: typing 1.4s infinite;
}

.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
  0%, 60%, 100% { opacity: 0.4; transform: scale(0.8); }
  30% { opacity: 1; transform: scale(1); }
}

.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: white;
  border-top: 1rpx solid #eee;
}

.input {
  flex: 1;
  height: 80rpx;
  padding: 0 30rpx;
  background: #f5f5f7;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.send-btn {
  width: 140rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: #007AFF;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
  margin-left: 20rpx;
}

.send-btn[disabled] {
  background: #ccc;
}
